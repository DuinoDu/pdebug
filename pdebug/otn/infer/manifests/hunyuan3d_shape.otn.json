{
  "name": "hunyuan3d_shape",
  "task": "inference",
  "description": "Generate 3D mesh from single image using Hunyuan3D-Shape model.",
  "backend": {
    "type": "legacy_python",
    "function": "hunyuan3d_shape_main",
    "module": "pdebug.otn.infer.hunyuan3d_shape"
  },
  "schemas": {
    "input": "LegacyPythonCall",
    "output": "LegacyPythonReturn"
  },
  "parameters": {
    "repo": {
      "type": "str"
    },
    "input_path": {
      "type": "str"
    },
    "output": {
      "type": "str",
      "default": "tmp_hunyuan3d_shape"
    },
    "model_path": {
      "type": "str",
      "default": "tencent/Hunyuan3D-2.1"
    },
    "octree_resolution": {
      "type": "int",
      "default": 256
    },
    "num_inference_steps": {
      "type": "int",
      "default": 5
    },
    "guidance_scale": {
      "type": "float",
      "default": 5.0
    },
    "num_chunks": {
      "type": "int",
      "default": 8000
    },
    "seed": {
      "type": "int",
      "default": 1234
    },
    "cache": {
      "type": "bool",
      "default": true
    }
  },
  "dependencies": {
    "extras": [
      "otn"
    ]
  },
  "capabilities": {
    "batch": false,
    "lance": false,
    "devices": [
      "cpu",
      "cuda"
    ]
  }
}
